{
  "name": "bizra-genesis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "node scripts/run-vitest.cjs run",
    "test:unit": "node scripts/run-vitest.cjs run",
    "test:watch": "node scripts/run-vitest.cjs",
    "test:coverage": "node scripts/run-vitest.cjs run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "lighthouse": "lhci autorun",
    "k6:smoke": "k6 run tests/k6/smoke.js",
    "k6:load": "k6 run tests/k6/load.js",
    "analyze": "ANALYZE=true next build",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "ci:security": "npm audit --audit-level=high",
    "docker:build": "docker build -t bizra-genesis:latest .",
    "docker:run": "docker run -p 3000:3000 bizra-genesis:latest",
    "docker:dev": "docker compose --profile dev up",
    "docker:prod": "docker compose --profile prod up --build",
    "release:check": "npx semantic-release --dry-run",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@react-three/postprocessing": "^3.0.4",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "@types/three": "^0.160.0",
    "autoprefixer": "^10.4.20",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "framer-motion": "latest",
    "gsap": "^3.14.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.454.0",
    "mermaid": "^11.12.2",
    "next": "^16.0.7",
    "react": "19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.181.2",
    "zustand": "latest"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@lhci/cli": "^0.13.0",
    "@next/eslint-plugin-next": "^16.0.6",
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.1.9",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.0",
    "baseline-browser-mapping": "^2.8.32",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.6",
    "jsdom": "^24.0.0",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5",
    "typescript-eslint": "^8.48.1",
    "vitest": "^1.6.0",
    "webpack-bundle-analyzer": "^4.10.1"
  }
}
