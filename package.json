{
  "name": "bizra-genesis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "node scripts/run-vitest.cjs run",
    "test:unit": "node scripts/run-vitest.cjs run",
    "test:integration": "node scripts/run-vitest.cjs run",
    "test:watch": "node scripts/run-vitest.cjs",
    "test:coverage": "node scripts/run-vitest.cjs run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "lighthouse": "lhci autorun",
    "k6:smoke": "k6 run tests/k6/smoke.js",
    "k6:load": "k6 run tests/k6/load.js",
    "analyze": "ANALYZE=true next build",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "ci:security": "npm audit --audit-level=high",
    "docker:build": "docker build -t bizra-genesis:latest .",
    "docker:run": "docker run -p 3000:3000 bizra-genesis:latest",
    "docker:dev": "docker compose --profile dev up",
    "docker:prod": "docker compose --profile prod up --build",
    "release:check": "npx semantic-release --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "@types/three": "^0.160.0",
    "autoprefixer": "^10.5.0",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "framer-motion": "latest",
    "gsap": "^3.15.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.454.0",
    "mermaid": "^11.14.0",
    "next": "^16.2.4",
    "react": "19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.5",
    "redis": "^4.7.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.181.2",
    "zustand": "latest"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.13.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "baseline-browser-mapping": "^2.10.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.4.32": "8.5.10",
      "tar-fs@<3.0.10": "3.0.10",
      "basic-ftp@<5.0.5": "5.0.5",
      "ws@<8.18.3": "8.18.3",
      "rollup@<4.22.4": "4.24.0",
      "flatted@<3.3.3": "3.3.3",
      "lodash": "4.17.21",
      "lodash-es": "4.17.21",
      "minimatch@<9.0.3": "9.0.3"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ],
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
