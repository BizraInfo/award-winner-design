# BIZRA Genesis Environment Configuration
# Copy this file to .env.local and fill in the values

# =============================================================================
# SECURITY SECRETS (Required for production)
# =============================================================================

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-256-bit-jwt-secret-change-in-production
REFRESH_SECRET=your-256-bit-refresh-secret-change-in-production

# CSRF Protection
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=your-csrf-secret-change-in-production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bizra_genesis

# Redis (for session/token storage)
REDIS_URL=redis://localhost:6379

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Configuration
API_BASE_URL=http://localhost:3000/api

# Scaffold (Python) API Bridge
SCAFFOLD_API_URL=http://localhost:8000
NEXT_PUBLIC_NODE_HEALTH_URL=/api/scaffold/health

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# =============================================================================
# CI/CD SECRETS (Set in GitHub Actions)
# =============================================================================

# These should be set as GitHub repository secrets, not in .env files:
# - SNYK_TOKEN
# - CODECOV_TOKEN
# - GITLEAKS_LICENSE
# - KUBE_CONFIG_STAGING
# - KUBE_CONFIG_PRODUCTION
# - SLACK_WEBHOOK_URL
