# BIZRA Genesis Environment Configuration
# Copy this file to .env.local and fill in the values

# =============================================================================
# SECURITY SECRETS (Required for production)
# =============================================================================

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-256-bit-jwt-secret-change-in-production
REFRESH_SECRET=your-256-bit-refresh-secret-change-in-production

# CSRF Protection
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=your-csrf-secret-change-in-production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/bizra_genesis

# Redis (for session/token storage and cross-instance member registry)
REDIS_URL=redis://localhost:6379

# When true, genesis onboarding fails if REDIS_URL is unset (strict server persistence).
# Default: false — client-local keys in browser are allowed when Redis is disabled.
# BIZRA_REQUIRE_REDIS_FOR_ONBOARDING=false

# Beta access (production defaults to invitation-only)
# BIZRA_ACCESS_MODE=invite_only
# Comma-separated invite codes (lowercase compare). Required for verify-invite in production.
# BIZRA_BETA_INVITE_CODES=design-partner-1,founder-alpha
# HMAC secret for bizra_beta_admit cookie (falls back to JWT_SECRET)
# BIZRA_BETA_GATE_SECRET=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Configuration
API_BASE_URL=http://localhost:3000/api

# Sovereign Python Backend (proxy target for /api/v1/* routes)
# Default: python -m core.sovereign serve --port 8080
SOVEREIGN_API_URL=http://localhost:8080

# Legacy Scaffold API Bridge (fallback if SOVEREIGN_API_URL not set)
SCAFFOLD_API_URL=http://localhost:8000
NEXT_PUBLIC_NODE_HEALTH_URL=/api/scaffold/health

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# =============================================================================
# CI/CD SECRETS (Set in GitHub Actions)
# =============================================================================

# These should be set as GitHub repository secrets, not in .env files:
# - SNYK_TOKEN
# - CODECOV_TOKEN
# - GITLEAKS_LICENSE
# - KUBE_CONFIG_STAGING
# - KUBE_CONFIG_PRODUCTION
# - SLACK_WEBHOOK_URL
